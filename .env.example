# Discord bot token
DISCORD_TOKEN=your_discord_bot_token

# Announcement channel where update links are posted
ANNOUNCEMENT_CHANNEL_ID=your_announcement_channel_id

# Poll frequency in minutes
CHECK_INTERVAL_MINUTES=10

# Optional: set to true if you want the bot to announce current latest entries
# the first time it starts with an empty state file.
ANNOUNCE_ON_FIRST_RUN=false

# RoyalRoad feeds (JSON array)
# Each source can have its own role IDs.
# Example:
# [{"name":"Story A","url":"https://www.royalroad.com/fiction/syndication/12345","roleIds":["111111111111111111","222222222222222222"]}]
ROYALROAD_FEEDS_JSON=[]

# Patreon feeds (JSON array)
# Example:
# [{"name":"Patreon Main","url":"https://www.patreon.com/rss/YOUR_RSS_TOKEN","roleIds":["333333333333333333"]}]
PATREON_FEEDS_JSON=[]
