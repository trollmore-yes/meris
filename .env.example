# Discord bot token
DISCORD_TOKEN=your_discord_bot_token

# Announcement channel where update links are posted
ANNOUNCEMENT_CHANNEL_ID=your_announcement_channel_id

# Poll frequency in minutes
CHECK_INTERVAL_MINUTES=10

# Optional: set to true if you want the bot to announce current latest entries
# the first time it starts with an empty state file.
ANNOUNCE_ON_FIRST_RUN=false

# Optional: directory for persistent state/config files (state.json, guild_config.json)
# If omitted, defaults to ./data in the project root.
# Example: /var/lib/meris
MERIS_DATA_DIR=

# RoyalRoad feeds (JSON array)
# Example:
# [{"name":"Story A","url":"https://www.royalroad.com/fiction/syndication/12345"}]
ROYALROAD_FEEDS_JSON=[]

# Patreon feeds (JSON array)
# Patreon API access token (required for member-only post detection)
# Get it from: https://www.patreon.com/portal/registration/register-clients
# -> Your client page shows "Creator's Access Token" — paste it here
# PATREON_ACCESS_TOKEN=
# Or use client credentials + refresh token (also on the client page):
# PATREON_CLIENT_ID=
# PATREON_CLIENT_SECRET=
# PATREON_REFRESH_TOKEN=

# Patreon feeds — creator page URL or RSS URL:
# [{"name":"Patreon Main","url":"https://www.patreon.com/c/yourslug"}]
PATREON_FEEDS_JSON=[]
